			"com.chaosroll.ChaosRollMod"
		],
		"client": [
			"com.chaosroll.client.ChaosRollClient"
		]
	},
	"mixins": [
		"chaosroll.mixins.json",
		{
			"config": "chaosroll.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": "~1.21.1",
		"java": ">=21",
