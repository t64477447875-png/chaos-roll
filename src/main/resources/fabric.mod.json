{
	"schemaVersion": 1,
	"id": "chaosroll",
	"version": "${version}",
	"name": "Chaos Roll",
	"description": "Кожну хвилину з'являється кнопка ROLL — натисни R і отримай одну з 70 випадкових подій. Підтримує мультиплеєр.",
	"authors": [
		"Артем"
	],
	"contact": {
		"sources": "https://github.com/Zeus998-lol/chaos-roll"
	},
	"license": "MIT",
